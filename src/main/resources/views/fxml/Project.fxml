<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.yourapp.controller.ProjectController"
            prefWidth="1200" prefHeight="800">

    <!--  SIDEBAR  -->
    <left>
        <VBox spacing="20" style="-fx-background-color:#0f172a;" prefWidth="230" alignment="TOP_CENTER">
            <Label text="Audit Doc AI" style="-fx-text-fill:white; -fx-font-size:20px; -fx-font-weight:bold;" />
            <Button text="Tableau de Bord" style="-fx-background-color:transparent; -fx-text-fill:white;" />
            <Button text="Audit" style="-fx-background-color:transparent; -fx-text-fill:white;" />
            <Button text="Projets" style="-fx-background-color:#0ea5e9; -fx-text-fill:white;" />
            <Button text="Historique" style="-fx-background-color:transparent; -fx-text-fill:white;" />
            <Button text="Paramètres" style="-fx-background-color:transparent; -fx-text-fill:white;" />
        </VBox>
    </left>

    <!--  CONTENT  -->
    <center>
        <VBox spacing="20" padding="20">

            <!--  TOP BAR  -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <TextField promptText="Rechercher un projet..." prefWidth="500"/>
                <Button text="+ Créer un Projet"
                        onAction="#openCreateProjectPopup"
                        style="-fx-background-color:#2563eb; -fx-text-fill:white; -fx-padding:10 20; -fx-background-radius:8;" />
            </HBox>

            <Label text="Projets" style="-fx-font-size:28px; -fx-font-weight:bold;" />

            <!--  GRID OF PROJECT CARDS  -->
            <ScrollPane fitToWidth="true" style="-fx-background-color:transparent;">
                <FlowPane fx:id="projectContainer"
                          hgap="20" vgap="20"
                          padding="10,10,10,10"
                          prefWidth="1000">
                </FlowPane>
            </ScrollPane>

        </VBox>
    </center>
</BorderPane>
